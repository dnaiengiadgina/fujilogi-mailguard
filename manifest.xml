<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>A1B2C3D4-E5F6-7890-ABCD-EF1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>FujilogiMailGuard</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="FujilogiMailGuard"/>
  <Description DefaultValue="Mail send confirmation addin"/>
  <IconUrl DefaultValue="https://dnaiengiadgina.github.io/fujilogi-mailguard/icon.png"/>
  <HighResolutionIconUrl DefaultValue="https://dnaiengiadgina.github.io/fujilogi-mailguard/icon.png"/>
  <SupportUrl DefaultValue="https://dnaiengiadgina.github.io/fujilogi-mailguard/"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://dnaiengiadgina.github.io/fujilogi-mailguard/dialog.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets>
        <bt:Set Name="Mailbox" MinVersion="1.12"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <Runtimes>
            <Runtime resid="WebViewRuntime.Url">
              <Override type="javascript" resid="JSRuntime.Url"/>
            </Runtime>
          </Runtimes>
          <FunctionFile resid="WebViewRuntime.Url"/>
          <ExtensionPoint xsi:type="LaunchEvent">
            <LaunchEvents>
              <LaunchEvent Type="OnMessageSend" FunctionName="onMessageSendHandler" SendMode="PromptUser"/>
            </LaunchEvents>
            <SourceLocation resid="WebViewRuntime.Url"/>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Urls>
        <bt:Url id="WebViewRuntime.Url" DefaultValue="https://dnaiengiadgina.github.io/fujilogi-mailguard/commands.html"/>
        <bt:Url id="JSRuntime.Url" DefaultValue="https://dnaiengiadgina.github.io/fujilogi-mailguard/commands.js"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="AddInName" DefaultValue="FujilogiMailGuard"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="AddInDescription" DefaultValue="Mail send confirmation addin"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
